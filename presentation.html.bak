<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>IADT AdminPortal — Student Retention Analysis</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/reset.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/reveal.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/theme/moon.css">

  <style>
    @font-face {
      font-family: 'Circular';
      src: url('data:font/otf;base64,') format('opentype');
      font-weight: 400; font-style: normal;
    }
    @font-face {
      font-family: 'Circular';
      src: url('data:font/otf;base64,') format('opentype');
      font-weight: 700; font-style: normal;
    }
    @font-face {
      font-family: 'Circular';
      src: url('data:font/otf;base64,') format('opentype');
      font-weight: 900; font-style: normal;
    }

    :root {
      --gold:    	#FFB500;
      --sky:     	#59CBE8;
      --red:     	#F8485E;
      --orange: rgba(255, 71, 19, 0.98);
      --green:   	#00BFB3;
      --purple: #9063CD;
      --dim:    rgba(255,255,255,0.48);
      --card:   rgba(255,255,255,0.055);
      --border: rgba(255,255,255,0.11);
    }

    .reveal-viewport, body { background: #0b1629 !important; }
    .reveal .slide-background { background: #000 !important; }

    .reveal {
      font-family: 'Circular', -apple-system, BlinkMacSystemFont, 'Segoe UI',
                   'Helvetica Neue', Arial, sans-serif;
    }
    .reveal h1, .reveal h2 {
      font-family: inherit; color: #f0f4f8;
      text-transform: none; letter-spacing: -0.025em;
    }
    .reveal h2 { color: var(--orange) !important; }
    .reveal h2 { font-size: 40px !important; margin-bottom: 8px; line-height: 1.15; }
    .reveal h2::after {
      content: ''; display: block; width: 48px; height: 4px;
      background: var(--orange); border-radius: 2px; margin-top: 7px;
    }
    .reveal h3 { font-size: 20px !important; color: var(--sky); margin: 0 0 8px; }
    .reveal p  { color: rgba(255,255,255,0.85); line-height: 1.6; margin: 0 0 8px; font-size: 18px; }
    .reveal li { color: rgba(255,255,255,0.85); font-size: 18px; }
    .reveal code {
      background: rgba(255,255,255,0.1); border-radius: 4px;
      padding: 0.12em 0.45em; font-size: 0.85em; color: var(--sky);
    }

    .accent  { color: var(--gold); }
    .sky     { color: var(--sky); }
    .danger  { color: var(--red); }
    .success { color: var(--green); }
    .dim     { color: var(--dim); }
    .bold    { font-weight: 700; }
    .sm      { font-size: 17px; }
    .xs      { font-size: 14px; }

    .pill {
      display: inline-block; border-radius: 20px;
      padding: 3px 12px; font-size: 13px; font-weight: 500; margin: 2px;
    }
    .pill-sky   { background:rgba(56,189,248,0.14);  border:1px solid rgba(56,189,248,0.28);  color:var(--sky); }
    .pill-gold  { background:rgba(245,158,11,0.14);  border:1px solid rgba(245,158,11,0.28);  color:var(--gold); }
    .pill-red   { background:rgba(248,113,113,0.14); border:1px solid rgba(248,113,113,0.28); color:var(--red); }
    .pill-green { background:rgba(52,211,153,0.14);  border:1px solid rgba(52,211,153,0.28);  color:var(--green); }
    .pill-purple{ background:rgba(167,139,250,0.14); border:1px solid rgba(167,139,250,0.28); color:var(--purple); }

    .stat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin:14px 0; }
    .stat-box {
      background:var(--card); border:1px solid var(--border);
      border-radius:14px; padding:20px 14px; text-align:center;
    }
    .stat-box .big   { font-size:56px; font-weight:700; color:var(--gold); line-height:1; }
    .stat-box .label { font-size:13px; color:var(--dim); margin-top:8px; line-height:1.45; }

    .callout {
      background:var(--card); border-left:3px solid var(--gold);
      border-radius:0 10px 10px 0; padding:12px 16px;
      font-size:16px; margin:10px 0; line-height:1.5;
    }

    .feature-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin:12px 0; }
    .feature-card {
      background:var(--card); border:1px solid var(--border);
      border-radius:12px; padding:16px 12px; text-align:center;
    }
    .feature-card .fc-icon { font-size:28px; margin-bottom:6px; }
    .feature-card .fc-name { font-size:16px; font-weight:600; color:var(--sky); }
    .feature-card .fc-desc { font-size:13px; color:var(--dim); margin-top:5px; line-height:1.45; }

    .info-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .info-card {
      background:var(--card); border-radius:10px; padding:14px 16px;
      font-size:15px; color:rgba(255,255,255,0.82);
      border:1px solid var(--border); line-height:1.5;
    }

    .arch-flow { display:flex; align-items:center; justify-content:center; margin:18px 0 14px; }
    .arch-box {
      background:var(--card); border:1px solid var(--border);
      border-radius:12px; padding:14px 18px; text-align:center; min-width:145px;
    }
    .arch-box .ab-tag  { font-size:11px; color:var(--dim); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:4px; }
    .arch-box .ab-name { font-size:18px; font-weight:600; }
    .arch-box .ab-sub  { font-size:12px; color:var(--dim); margin-top:4px; line-height:1.4; }
    .arch-arrow {
      display:flex; flex-direction:column; align-items:center;
      justify-content:center; padding:0 8px; color:var(--gold); font-size:12px; gap:2px;
    }
    .arch-arrow .arr { font-size:26px; line-height:1; }

    .data-badges { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
    .data-badge {
      background:var(--card); border-radius:10px;
      padding:12px 14px; font-size:13px; border:1px solid var(--border); line-height:1.45;
    }
    .data-badge strong { display:block; margin-bottom:4px; font-size:14px; }

    .chart-wrap { position:relative; width:100%; }

    .two-col { display:grid; grid-template-columns:1fr 1fr; gap:18px; }

    .legend-row {
      display:flex; gap:18px; justify-content:flex-end;
      align-items:center; margin-top:8px; font-size:13px;
    }
    .legend-row span { display:flex; align-items:center; gap:5px; color:var(--dim); }
    .ldot { display:inline-block; width:12px; height:12px; border-radius:3px; flex-shrink:0; }

    .limit-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .limit-item {
      background:var(--card); border-left:3px solid var(--gold);
      border-radius:0 10px 10px 0; padding:12px 16px;
    }
    .limit-item strong { color:var(--gold); display:block; margin-bottom:4px; font-size:15px; }
    .limit-item span   { color:rgba(255,255,255,0.74); line-height:1.45; font-size:14px; }

    .next-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .next-item {
      background:rgba(52,211,153,0.065); border:1px solid rgba(52,211,153,0.2);
      border-radius:12px; padding:14px 16px;
    }
    .next-item .step-num { font-size:24px; font-weight:700; color:var(--green); line-height:1; }
    .next-item p { margin:5px 0 0; color:rgba(255,255,255,0.82); font-size:14px; line-height:1.5; }

    .reveal .slides section { padding:36px 48px; box-sizing:border-box; }
    .reveal .progress span  { background:var(--orange); }
    .reveal .controls       { color:var(--sky); }
    .reveal .slide-number   { font-size:13px !important; }

    /* title slide */
    #slide-title {
      background:
        radial-gradient(ellipse at 18% 62%, rgba(56,189,248,0.11) 0%, transparent 52%),
        radial-gradient(ellipse at 82% 22%, rgba(245,158,11,0.08) 0%, transparent 48%),
        #0b1629 !important;
    }
    .title-institute { font-size:13px; color:var(--dim); letter-spacing:0.14em; text-transform:uppercase; margin-bottom:28px; }
    #slide-title h1  { font-size:64px !important; line-height:1.1; margin-bottom:4px; }
    .title-subtitle  { font-size:22px; color:var(--sky); margin:8px 0 20px; line-height:1.5; }
    .title-tagline   { font-size:16px; color:var(--dim); font-style:italic; margin-bottom:28px; }
    .title-nav-hint  {
      position:absolute; bottom:20px; right:48px;
      font-size:12px; color:rgba(255,255,255,0.18); letter-spacing:0.06em;
    }
    .title-top-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .title-iadt-logo { height:62px; opacity:0.7; }
    .title-app-row { display:flex; align-items:center; justify-content:center; gap:14px; }
    .title-app-icon { width:54px; height:54px; flex-shrink:0; }

  </style>
</head>

<body>
<div class="reveal">
<div class="slides">

<!-- ══ SLIDE 1 — TITLE ══════════════════════════════════════════ -->
<section id="slide-title">
  <div class="title-top-row">
    <span></span>
    <img class="title-iadt-logo" src="data:image/png;base64," alt="IADT">
  </div>
  <div class="title-institute">Dún Laoghaire Institute of Art, Design &amp; Technology</div>
  <div class="title-app-row">
    <div class="title-app-icon"><svg version="1.1" id="Layer_1"
     xmlns="http://www.w3.org/2000/svg"
     xmlns:xlink="http://www.w3.org/1999/xlink"
     x="0px" y="0px"
     viewBox="0 0 122.88 120.5"
     style="enable-background:new 0 0 122.88 120.5"
     xml:space="preserve">
  <g>
    <!-- Small black piece (now red) -->
    <path fill="purple" d="M64.82,68.27l48.4,0.8c0,17.19-8.55,33.26-22.81,42.86L64.82,68.27L64.82,68.27z"/>

    <!-- Large black piece (now blue) -->
    <path fill="#3498db" d="M59.99,59.92L59.44,3.63 L59.41,0l3.61,0.25h0.01h0.01c4.56,0.32,8.98,1.12,13.21,2.33c4.23,1.21,8.29,2.86,12.13,4.87c19.67,10.34,33.27,30.56,34.34,54.02 l0.16,3.61l-3.61-0.11l-56.02-1.72l-3.23-0.1L59.99,59.92L59.99,59.92z"/>

    <!-- Hollow slice (now green) -->
    <path fill="#2ecc71" d="M66.19,7.33l0.48,49.31l49.06,1.5 c-2.1-19.45-13.88-36.02-30.48-44.74c-3.41-1.79-7.04-3.26-10.84-4.35C71.74,8.28,69,7.71,66.19,7.33L66.19,7.33z"/>

    <!-- The rest of the pie (gray background) -->
    <path fill="rgba(255,71,19,0.98)" d="M55.19,65.31l27.6,47.8c-8.38,4.84-17.92,7.39-27.6,7.39C24.71,120.5,0,95.78,0,65.31c0-29.57,23.31-53.9,52.86-55.14L55.19,65.31L55.19,65.31z"/>
  </g>
</svg></div>
    <h1>IADT <span class="accent">AdminPortal</span></h1>
  </div>
  <div class="title-subtitle">
    Analysing Academic Performance &amp; Dropout Patterns<br>
    Through Interactive Data Visualisation
  </div>
  <div class="title-tagline">A data-driven approach to student retention</div>
  <div>
    <span class="pill pill-sky">FastAPI · Vue 3 · PostgreSQL</span>
    <span class="pill pill-gold">Banner SIS</span>
    <span class="pill pill-green">IADT Hub</span>
    <span class="pill pill-purple">Entra ID</span>
    <span class="pill pill-red">EventMap Timetabler</span>
  </div>
  <div class="title-nav-hint">← → to navigate · S for speaker notes · F for fullscreen</div>
  <aside class="notes">20 s. Welcome; name the platform. Today's question: where and why do students disengage?</aside>
</section>

<!-- ══ SLIDE 2 — THE PROBLEM ════════════════════════════════════ -->
<section>
  <h2>The <span class="accent">Problem</span></h2>
  <p class="sm">Irish higher education faces persistent dropout challenges — with direct consequences for students, institutions, and national workforce outcomes.</p>
  <div class="stat-grid">
    <div class="stat-box fragment">
      <div class="big">~15–25%</div>
      <div class="label">Non-completion rates across Irish HE — higher for part-time &amp; distance programmes<br><span style="opacity:0.6">(HEA Performance Profiles)</span></div>
    </div>
    <div class="stat-box fragment">
      <div class="big">Year 2–3</div>
      <div class="label">Peak attrition window — where academic pressure, financial strain, and life commitments converge</div>
    </div>
    <div class="stat-box fragment">
      <div class="big">Reactive</div>
      <div class="label">Most institutions only <em>notice</em> dropout after it happens — rarely in time to intervene</div>
    </div>
  </div>
  <div class="callout fragment">
    <strong class="accent">The gap:</strong> Enrolment, grade, and timetable data exist in Banner, AdminPortal, and EventMap — held in separate systems, rarely synthesised into a single actionable retention signal.
  </div>
  <aside class="notes">45 s. Non-completion figures from HEA Performance Profiles vary by programme type. The problem is latency between signal and response.</aside>
</section>

<!-- ══ SLIDE 3 — THE TOOL ════════════════════════════════════════ -->
<section>
  <h2>The <span class="accent">Tool</span></h2>
  <p class="sm">IADT AdminPortal is a full-stack grade management and institutional reporting platform — Banner SIS as the authoritative source of truth, surfaced through a modern web interface.</p>
  <div class="feature-grid fragment">
    <div class="feature-card">
      <div class="fc-icon">📊</div>
      <div class="fc-name">Reporting</div>
      <div class="fc-desc">Enrolment trends, dropout rates, grade distributions — per programme and institution-wide</div>
    </div>
    <div class="feature-card">
      <div class="fc-icon">✅</div>
      <div class="fc-name">Grade Centre</div>
      <div class="fc-desc">Structured grade entry, approval workflow, and sign-off audit trail per CRN</div>
    </div>
    <div class="feature-card">
      <div class="fc-icon">🔄</div>
      <div class="fc-name">Live Sync</div>
      <div class="fc-desc">Nightly Banner mirror, hourly Timetabler &amp; Dataverse sync — no manual exports</div>
    </div>
    <div class="feature-card">
      <div class="fc-icon">🔒</div>
      <div class="fc-name">RBAC</div>
      <div class="fc-desc">Role-based access (admin · manager · lecturer) via Entra ID with permission-scoped endpoints</div>
    </div>
  </div>
  <div class="info-row fragment">
    <div class="info-card">
      <span class="sky bold">/reporting</span> exposes enrolment trend charts, programme drill-downs, and dropout rate analysis — Banner mirror queried in real time, visualised in Vue.js with Chart.js.
    </div>
    <div class="info-card">
      The <span class="sky bold">drill-down modal</span> is triggered by clicking any bar in the enrolment trend chart — surfaces a per-programme breakdown for that specific term in an overlay panel.
    </div>
  </div>
  <aside class="notes">60 s. Banner remains the source of truth — AdminPortal reads from it via a nightly-synced mirror. Analytics never write to Banner.</aside>
</section>

<!-- ══ SLIDE 4 — DATA ARCHITECTURE ══════════════════════════════ -->
<section>
  <h2>Data <span class="accent">Architecture</span></h2>
  <div class="arch-flow fragment">
    <div class="arch-box" style="border-color:rgba(245,158,11,0.4)">
      <div class="ab-tag">Source System</div>
      <div class="ab-name" style="color:var(--gold)">Banner SIS</div>
      <div class="ab-sub">SFRSTCR · SGBSTDN<br>SSBSECT · SPRIDEN<br>SIRASGN · SMRPRLE</div>
    </div>
    <div class="arch-arrow"><div class="arr">→</div><div>nightly sync</div></div>
    <div class="arch-box" style="border-color:rgba(56,189,248,0.4)">
      <div class="ab-tag">PostgreSQL Mirror</div>
      <div class="ab-name" style="color:var(--sky)">banner_mirror</div>
      <div class="ab-sub">Read-only replica<br><code>reporting_user</code><br>SELECT only</div>
    </div>
    <div class="arch-arrow"><div class="arr">→</div><div>on-demand</div></div>
    <div class="arch-box" style="border-color:rgba(52,211,153,0.4)">
      <div class="ab-tag">Application Layer</div>
      <div class="ab-name" style="color:var(--green)">AdminPortal API</div>
      <div class="ab-sub">FastAPI /reporting<br>Vue.js dashboard<br>Chart.js charts</div>
    </div>
    <div class="arch-arrow"><div class="arr">→</div><div>renders</div></div>
    <div class="arch-box" style="border-color:rgba(167,139,250,0.4)">
      <div class="ab-tag">End User</div>
      <div class="ab-name" style="color:var(--purple)">Browser</div>
      <div class="ab-sub">Entra ID SSO<br>RBAC enforced<br>drill-down UI</div>
    </div>
  </div>
  <div class="data-badges fragment">
    <div class="data-badge" style="border-left:3px solid var(--sky)">
      <strong class="sky">Enrolment &amp; cohort data</strong>
      <span class="dim">Refreshed nightly. Term code = one academic year: <code>202400</code> = 2024/25.</span>
    </div>
    <div class="data-badge" style="border-left:3px solid var(--green)">
      <strong class="success">Grade &amp; approval data</strong>
      <span class="dim">Submitted through AdminPortal directly — near-real-time via <code>grading_flow</code> schema.</span>
    </div>
    <div class="data-badge" style="border-left:3px solid var(--gold)">
      <strong class="accent">Timetable &amp; Dataverse</strong>
      <span class="dim">EventMap hourly sync; Dataverse enrolment push hourly. No manual exports required.</span>
    </div>
  </div>
  <aside class="notes">45 s. reporting_user is SELECT-only — zero risk to Banner. grading_flow handles writes separately.</aside>
</section>

<!-- ══ SLIDE 5 — IADT-WIDE ENROLMENT (REAL DATA) ════════════════ -->
<section>
  <h2>IADT-Wide <span class="accent">Enrolment Trends</span></h2>
  <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:8px">
    <p class="sm" style="margin:0">Distinct enrolled students per term — all programmes, <code>SFRSTCR</code> active registrations only. In the live app, clicking any bar opens the <span class="sky">per-programme drill-down modal</span>.</p>
    <span style="font-size:12px; color:var(--green); white-space:nowrap; margin-left:12px">✓ Live Banner data</span>
  </div>
  <div class="chart-wrap" style="height:360px"><canvas id="chart-enrollment"></canvas></div>
  <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px">
    <span class="xs dim">Stable at ~2,700 with modest growth — 2025/26 is the highest recorded intake at 2,822</span>
    <span class="pill pill-sky">Click bar → programme breakdown modal</span>
  </div>
  <aside class="notes">60 s. Walk through the bars. Enrollment is remarkably stable — ~2,700 across six years with a gentle upward trend in the most recent two. The drill-down modal in the live app breaks any bar down by programme. No COVID dip visible in Banner registrations — any disruption was absorbed differently here.</aside>
</section>

<!-- ══ SLIDE 6 — PROGRAMME INTAKE & INACTIVE RATE ═══════════════ -->
<section>
  <h2>Zooming In: <span class="accent">Intake &amp; Inactive Rate by Year</span></h2>
  <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:8px">
    <p class="sm" style="margin:0">DL_SCYPY_O annual student intake (bars) and the proportion carrying <span class="danger">Inactive status</span> (<code>SGBSTDN_STST_CODE = 'IS'</code>) by year-end (line).</p>
    <span style="font-size:12px; color:var(--green); white-space:nowrap; margin-left:12px">✓ Live Banner data</span>
  </div>
  <div class="chart-wrap" style="height:340px"><canvas id="chart-cohort"></canvas></div>
  <div style="margin-top:8px">
    <span class="pill pill-gold">1-year SP programme — most students enrol for a single academic year</span>
    <span class="pill pill-red">Inactive rate typically 11–23% per year</span>
    <span class="pill pill-sky">2020/21 largest cohort: 38 students</span>
  </div>
  <aside class="notes">75 s. This is a Special Purpose 1-year programme — the "cohort attrition" framing from multi-year degrees doesn't apply. What we can measure is: of students registered in a given year, what proportion carry Inactive status? That rate sits around 11–23%. The 2020/21 spike in intake (38 students) is notable — it's also the year with the highest absolute inactive count (8).</aside>
</section>

<!-- ══ SLIDE 7 — CENTREPIECE: ACTIVE vs INACTIVE ════════════════ -->
<section>
  <h2>'Intro to Cyberpsychology' — <span class="accent">Active vs Inactive</span></h2>
  <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:8px">
    <p class="sm" style="margin:0">PSYL_H3010 is the core module taken by all DL_SCYPY_O students. Per-year count of students with <span class="sky">Active</span> vs <span class="danger">Inactive</span> student status at year-end.</p>
    <span style="font-size:12px; color:var(--green); white-space:nowrap; margin-left:12px">✓ Live Banner data</span>
  </div>
  <div class="chart-wrap" style="height:370px"><canvas id="chart-modules"></canvas></div>
  <div class="legend-row">
    <span><span class="ldot" style="background:#38bdf8"></span>Active (<code>SGBSTDN_STST_CODE = 'AS'</code>)</span>
    <span><span class="ldot" style="background:#f87171"></span>Inactive (<code>'IS'</code>)</span>
    <span class="dim" style="font-size:12px; margin-left:8px">Aggregated counts only — no individual student data shown</span>
  </div>
  <aside class="notes">90 s. This is the centrepiece — PSYL_H3010, "Intro to Cyberpsychology", is the single core module for the whole programme. Every bar here represents real Banner data. Note the 2020/21 spike in total enrollment — also visible here as the tallest active bar. The inactive count has been lower and more consistent in recent years (3–4 students) compared to the 2017–2020 period (4–8). The 2024/25 inactive count of 6 is worth monitoring.</aside>
</section>

<!-- ══ SLIDE 8 — TIMING AND PATTERNS ════════════════════════════ -->
<section>
  <h2>Dropout <span class="accent">Timing &amp; Student Profile</span></h2>
  <div style="display:flex; justify-content:flex-end; margin-bottom:10px">
    <span style="font-size:12px; color:var(--green)">✓ Live Banner data</span>
  </div>
  <div class="two-col">
    <div>
      <h3>Last active term by year</h3>
      <div class="chart-wrap" style="height:280px"><canvas id="chart-timing"></canvas></div>
      <p class="xs dim" style="margin-top:6px">Students whose last non-dropped/withdrawn registration falls in that year — includes completers of this 1-year programme</p>
    </div>
    <div>
      <h3>Student type breakdown</h3>
      <div class="chart-wrap" style="height:280px"><canvas id="chart-demographics"></canvas></div>
      <p class="xs dim" style="margin-top:6px">Cohorts admitted 2020/21 onward. "Not active" = not registered in 2025/26 — includes both completers and dropouts</p>
    </div>
  </div>
  <aside class="notes">75 s. Left: the last-active-term chart peaks at 2020/21 (38) because it was the largest cohort — most "left" by completing the 1-year programme. Right: ACCS (Access) students are the largest group, with 56 not active since 2020 vs only 1 currently active. For a 1-year programme, most of these will be completers, not dropouts — SGBSTDN_STST_CODE breakdown is needed to distinguish. Query Q6 from the analytical spec.</aside>
</section>

<!-- ══ SLIDE 9 — LIMITATIONS ════════════════════════════════════ -->
<section>
  <h2>What the Data <span class="accent">Can't Yet Tell Us</span></h2>
  <p class="sm" style="margin-bottom:14px">The analysis is only as good as the data it's built on. Several key dimensions are currently absent or ambiguous.</p>
  <div class="limit-grid">
    <div class="limit-item fragment">
      <strong>Completion vs dropout conflated</strong>
      <span>For a 1-year programme, "not active next year" covers both successful completers and genuine dropouts. <code>SGBSTDN_STST_CODE</code> disambiguates — but graduate status codes need Admissions confirmation.</span>
    </div>
    <div class="limit-item fragment">
      <strong>No socioeconomic signal</strong>
      <span>Banner doesn't capture financial hardship, caring responsibilities, or employment hours — all documented dropout risk factors outside institutional view.</span>
    </div>
    <div class="limit-item fragment">
      <strong>RSTS code semantics</strong>
      <span>"Dropped" vs "Withdrawn" vs "Leave of Absence" may share code prefixes. Interpreting <code>SFRSTCR_RSTS_CODE</code> accurately requires Admissions confirmation of IADT's specific code set.</span>
    </div>
    <div class="limit-item fragment">
      <strong>Annual term granularity</strong>
      <span>One term code per academic year (<code>YYYY00</code>). Intra-year timing — October vs March withdrawal — is invisible at this resolution.</span>
    </div>
  </div>
  <p class="xs dim" style="margin-top:14px">Module readable names require a JOIN to <code>SCBCRSE</code>. PSYL_H3010 title confirmed: <em>"Intro to Cyberpsychology"</em>.</p>
  <aside class="notes">45 s. The most important limitation for this specific programme: we cannot yet distinguish students who completed from students who dropped out without additional status code analysis.</aside>
</section>

<!-- ══ SLIDE 10 — NEXT STEPS ═════════════════════════════════════ -->
<section>
  <h2>Next Steps &amp; <span class="accent">Conclusions</span></h2>
  <p class="sm" style="margin-bottom:14px">AdminPortal has proved the core proposition: <span class="success">centralised data access enables questions that weren't answerable before — in real time, against live data, for any programme.</span></p>
  <div class="next-grid">
    <div class="next-item fragment">
      <div class="step-num">01</div>
      <p><strong>Complete/dropout disambiguation</strong> — join <code>SGBSTDN_STST_CODE</code> to the inactive analysis to separate genuine dropouts from programme completers. This is the most urgent analytical gap.</p>
    </div>
    <div class="next-item fragment">
      <div class="step-num">02</div>
      <p><strong>Grade-to-dropout linkage</strong> — for students who became inactive, was there a grading signal in the same term? Query Q7 is already written to answer this.</p>
    </div>
    <div class="next-item fragment">
      <div class="step-num">03</div>
      <p><strong>Predictive flagging</strong> — combine grade trajectory with enrolment status to surface at-risk students <em>before</em> withdrawal, enabling earlier personal tutoring intervention.</p>
    </div>
    <div class="next-item fragment">
      <div class="step-num">04</div>
      <p><strong>Cross-programme patterns</strong> — the same analytical framework applies to any IADT programme. This is one example of a repeatable institution-scale analysis.</p>
    </div>
  </div>
  <p class="xs dim" style="margin-top:14px">The Banner write pipeline already exists (Dataverse, EventMap push). Feeding intervention flags <em>back</em> into SIS via the Student Management module is a near-term possibility.</p>
  <aside class="notes">45 s. The hard infrastructure is done. The most urgent next step is actually simple: add a status-code join to distinguish completers from dropouts. Every IADT programme can be analysed the same way. Invite questions.</aside>
</section>

</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/dist/reveal.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@4.5.0/plugin/zoom/zoom.js"></script>
<script>
  Reveal.initialize({
    hash: true, transition: 'slide', backgroundTransition: 'fade',
    progress: true, slideNumber: 'c/t', controls: true, center: true,
    width: 960, height: 600, margin: 0.02, minScale: 0.3, maxScale: 3.0,
    plugins: [ RevealZoom ]
  });

  Chart.defaults.color       = 'rgba(255,255,255,0.75)';
  Chart.defaults.font.family = "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif";
  Chart.defaults.font.size   = 13;
  Chart.defaults.plugins.legend.labels.boxWidth = 13;
  Chart.defaults.plugins.legend.labels.padding  = 12;

  const GRID   = 'rgba(255,255,255,0.07)';
  const SKY    = '#38bdf8';
  const GOLD   = '#f59e0b';
  const RED    = '#f87171';
  const GREEN  = '#34d399';
  const PURPLE = '#a78bfa';

  const charts = {};
  function mkChart(id, cfg) {
    if (charts[id]) return;
    const el = document.getElementById(id);
    if (el) charts[id] = new Chart(el, cfg);
  }

  const ax = (extra = {}) => ({
    grid:  { color: GRID },
    ticks: { color: 'rgba(255,255,255,0.72)', font: { size: 13 } },
    ...extra,
  });

  /* ── SLIDE 5: IADT-wide enrollment ─────────────────────────────
     Source: SELECT SFRSTCR_TERM_CODE, COUNT(DISTINCT SFRSTCR_PIDM)
     FROM banner_mirror.SFRSTCR WHERE RSTS_CODE NOT LIKE 'D%'
     Terms 201900–202500 ─────────────────────────────────────── */
  function initEnrollment() {
    const data = [2597, 2774, 2752, 2706, 2705, 2767, 2822];
    mkChart('chart-enrollment', {
      type: 'bar',
      data: {
        labels: ['2019/20','2020/21','2021/22','2022/23','2023/24','2024/25','2025/26'],
        datasets: [{
          label: 'Students enrolled',
          data,
          backgroundColor: data.map((_, i) => i === 6
            ? 'rgba(52,211,153,0.7)' : 'rgba(56,189,248,0.7)'),
          borderColor: data.map((_, i) => i === 6 ? GREEN : SKY),
          borderWidth: 2, borderRadius: 6,
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: c => ` ${c.parsed.y.toLocaleString()} students enrolled` } },
        },
        scales: {
          x: ax(),
          y: ax({ min: 2400, title: { display: true, text: 'Enrolled headcount', color: 'rgba(255,255,255,0.35)', font: { size: 12 } } }),
        },
      },
    });
  }

  /* ── SLIDE 6: Intake (bars) + inactive rate % (line) ───────────
     Source: Q4 query against DL_SCYPY_O, terms 201800–202500
     student_count / dropout_count / dropout_rate from banner_mirror ── */
  function initCohort() {
    const labels       = ['2018/19','2019/20','2020/21','2021/22','2022/23','2023/24','2024/25','2025/26'];
    const studentCount = [19, 23, 38, 27, 22, 29, 26, 25];
    const inactiveRate = [21.1, 21.7, 21.1, 11.1, 13.6, 13.8, 23.1, 12.0];

    mkChart('chart-cohort', {
      type: 'bar',
      data: {
        labels,
        datasets: [
          {
            type: 'bar',
            label: 'Students enrolled',
            data: studentCount,
            backgroundColor: 'rgba(56,189,248,0.65)',
            borderColor: SKY, borderWidth: 2, borderRadius: 5,
            yAxisID: 'y',
          },
          {
            type: 'line',
            label: 'Inactive rate (%)',
            data: inactiveRate,
            borderColor: RED, backgroundColor: 'rgba(248,113,113,0.1)',
            pointBackgroundColor: RED, pointRadius: 5,
            tension: 0.35, yAxisID: 'y2',
          },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.78)' } },
          tooltip: { mode: 'index', intersect: false },
        },
        scales: {
          x: ax(),
          y:  ax({ title: { display: true, text: 'Students enrolled', color: 'rgba(255,255,255,0.35)', font: { size: 12 } } }),
          y2: {
            position: 'right',
            grid: { display: false },
            ticks: { color: RED, font: { size: 12 }, callback: v => v + '%' },
            min: 0, max: 35,
            title: { display: true, text: 'Inactive rate', color: RED, font: { size: 12 } },
          },
        },
      },
    });
  }

  /* ── SLIDE 7: PSYL_H3010 Active vs Inactive per year ───────────
     Source: Q4 per-module query, PSYL_H3010 only, 201700–202500
     active = student_count - inactive_count ──────────────────── */
  function initModules() {
    const labels   = ['17/18','18/19','19/20','20/21','21/22','22/23','23/24','24/25','25/26'];
    const active   = [17, 15, 18, 30, 24, 19, 25, 20, 22];
    const inactive = [ 5,  4,  5,  8,  3,  3,  4,  6,  3];

    mkChart('chart-modules', {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label: 'Active (AS)',          data: active,   backgroundColor: 'rgba(56,189,248,0.72)',  borderColor: SKY, borderWidth: 2, borderRadius: 5 },
          { label: 'Inactive (IS)',         data: inactive, backgroundColor: 'rgba(248,113,113,0.72)', borderColor: RED, borderWidth: 2, borderRadius: 5 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { mode: 'index', intersect: false,
            callbacks: {
              afterBody: items => {
                const tot = items.reduce((s, i) => s + i.parsed.y, 0);
                const ia  = items.find(i => i.datasetIndex === 1);
                if (!ia) return [];
                return [`Inactive rate: ${Math.round(ia.parsed.y / tot * 100)}%`];
              },
            },
          },
        },
        scales: {
          x: ax(),
          y: ax({ title: { display: true, text: 'Student count', color: 'rgba(255,255,255,0.35)', font: { size: 12 } } }),
        },
      },
    });
  }

  /* ── SLIDE 8: Timing (Q5) + Student type (Q6) ─────────────────
     Q5: last active term, 201900–202400, DL_SCYPY_O students
     Q6: STVSTYP breakdown, cohorts 202000+, active vs not-active ── */
  function initTiming() {
    mkChart('chart-timing', {
      type: 'bar',
      data: {
        labels: ['2019/20','2020/21','2021/22','2022/23','2023/24','2024/25'],
        datasets: [{
          label: 'Students whose last active term was…',
          data: [24, 38, 26, 19, 25, 27],
          backgroundColor: ['rgba(245,158,11,0.65)','rgba(248,113,113,0.78)','rgba(245,158,11,0.65)','rgba(245,158,11,0.65)','rgba(245,158,11,0.65)','rgba(245,158,11,0.65)'],
          borderColor: [GOLD, RED, GOLD, GOLD, GOLD, GOLD],
          borderWidth: 2, borderRadius: 5,
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: c => ` ${c.parsed.y} students (last active this year)` } },
        },
        scales: { x: ax(), y: ax() },
      },
    });

    mkChart('chart-demographics', {
      type: 'bar',
      data: {
        labels: ['ACCS', 'New (not 1st time)', 'New First Time', 'Job Stimulus'],
        datasets: [
          { label: 'Active 2025/26',        data: [1, 26,  0,  0], backgroundColor: 'rgba(52,211,153,0.7)',  borderColor: GREEN, borderWidth: 2, borderRadius: 5 },
          { label: 'Not active 2025/26',    data: [56, 37, 24, 19], backgroundColor: 'rgba(248,113,113,0.7)', borderColor: RED,   borderWidth: 2, borderRadius: 5 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.78)', font: { size: 11 } } },
          tooltip: { mode: 'index', intersect: false },
        },
        scales: {
          x: ax({ ticks: { ...ax().ticks, font: { size: 11 } } }),
          y: ax(),
        },
      },
    });
  }

  const chartMap = { 4: initEnrollment, 5: initCohort, 6: initModules, 7: initTiming };
  const dispatch = idx => { if (chartMap[idx]) chartMap[idx](); };
  Reveal.on('ready',        e => dispatch(e.indexh));
  Reveal.on('slidechanged', e => dispatch(e.indexh));
</script>
</body>
</html>
